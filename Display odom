import React, { useEffect, useState } from "react";
import ROSLIB from "roslib";

function App() {

  const [robots, setRobots] = useState({});

  useEffect(() => {

    // ================= ROS CONNECTION =================

    const ros = new ROSLIB.Ros({
      url: "ws://localhost:9090"
    });

    ros.on("connection", () => {
      console.log("Connected");
    });

    ros.on("error", (error) => {
      console.log(error);
    });

    // ================= GET TOPICS =================

    ros.getTopics((result) => {

      console.log(result.topics);

      // Find all odom topics
      const odomTopics = result.topics.filter(topic =>
        topic.endsWith("/odom")
      );

      console.log("Detected Robots:", odomTopics);

      // ================= CREATE SUBSCRIBERS =================

      odomTopics.forEach((topicName) => {

        // Example:
        // /robot1/odom

        const namespace = topicName.split("/")[1];

        const odomListener = new ROSLIB.Topic({
          ros: ros,
          name: topicName,
          messageType: "nav_msgs/msg/Odometry"
        });

        odomListener.subscribe((msg) => {

          setRobots(prev => ({
            ...prev,

            [namespace]: {

              x: msg.pose.pose.position.x,
              y: msg.pose.pose.position.y

            }

          }));

        });

      });

    });

  }, []);

  // ================= RENDER =================

  return (

    <div
      style={{
        width: "100vw",
        height: "100vh",
        background: "#eeeeee",
        position: "relative",
        overflow: "hidden"
      }}
    >

      <h1>Dynamic Multi Robot Map</h1>

      {

        Object.entries(robots).map(([name, robot], index) => (

          <div
            key={name}
            style={{
              position: "absolute",

              left: robot.x * 50 + 400,
              top: robot.y * 50 + 300,

              width: 40,
              height: 40,

              borderRadius: "50%",

              background:
                index % 2 === 0
                  ? "red"
                  : "blue",

              color: "white",

              display: "flex",
              alignItems: "center",
              justifyContent: "center",

              fontSize: 10,

              transition: "0.1s"
            }}
          >
            {name}
          </div>

        ))

      }

    </div>

  );
}

export default App;






