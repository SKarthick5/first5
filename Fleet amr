# 5. src/App.js

```javascript
import React, { useEffect, useState } from 'react'

import ros from './ros/ros'

import FleetHeader from './components/FleetHeader'
import RobotMap from './components/RobotMap'
import RobotList from './components/RobotList'

function App() {

  const [robots, setRobots] = useState({})

  useEffect(() => {

    ros.getTopics((result) => {

      const odomTopics = result.topics.filter(topic =>
        topic.endsWith('/odom')
      )

      odomTopics.forEach((topicName) => {

        const robotName = topicName.split('/')[1]

        const odomTopic = new window.ROSLIB.Topic({
          ros: ros,
          name: topicName,
          messageType: 'nav_msgs/msg/Odometry'
        })

        odomTopic.subscribe((msg) => {

          const position = msg.pose.pose.position
          const orientation = msg.pose.pose.orientation

          const siny_cosp = 2 * (
            orientation.w * orientation.z +
            orientation.x * orientation.y
          )

          const cosy_cosp = 1 - 2 * (
            orientation.y * orientation.y +
            orientation.z * orientation.z
          )

          const yaw = Math.atan2(siny_cosp, cosy_cosp)

          setRobots(prev => ({
            ...prev,

            [robotName]: {
              ...prev[robotName],

              x: position.x,
              y: position.y,
              yaw: yaw,

              active: true,

              battery: prev[robotName]?.battery ||
                Math.floor(Math.random() * 100),

              task: prev[robotName]?.task ||
                'Idle',

              lastUpdate: Date.now()
            }
          }))

        })

      })

    })

  }, [])

  useEffect(() => {

    const interval = setInterval(() => {

      setRobots(prev => {

        const updated = { ...prev }

        Object.keys(updated).forEach(name => {

          const robot = updated[name]

          if (Date.now() - robot.lastUpdate > 5000) {
            updated[name].active = false
          }

        })

        return updated

      })

    }, 1000)

    return () => clearInterval(interval)

  }, [])

  return (

    <div className='w-full min-h-screen bg-gray-100 p-4'>

      <FleetHeader robots={robots} />

      <div className='grid grid-cols-12 gap-4 mt-4'>

        <div className='col-span-8'>
          <RobotMap robots={robots} />
        </div>

        <div className='col-span-4'>
          <RobotList robots={robots} />
        </div>

      </div>

    </div>

  )
}

export default App
```

