import React from 'react'

function FleetHeader({ robots }) {

  const totalRobots = Object.keys(robots).length

  const activeRobots = Object.values(robots)
    .filter(robot => robot.active)
    .length

  const inactiveRobots = totalRobots - activeRobots

  return (

    <div className='bg-white rounded-2xl shadow p-4'>

      <div className='grid grid-cols-3 gap-4'>

        <div className='bg-blue-100 p-4 rounded-xl'>
          <h1 className='text-xl font-bold'>Total Robots</h1>
          <p className='text-3xl'>{totalRobots}</p>
        </div>

        <div className='bg-green-100 p-4 rounded-xl'>
          <h1 className='text-xl font-bold'>Active</h1>
          <p className='text-3xl'>{activeRobots}</p>
        </div>

        <div className='bg-red-100 p-4 rounded-xl'>
          <h1 className='text-xl font-bold'>Inactive</h1>
          <p className='text-3xl'>{inactiveRobots}</p>
        </div>

      </div>

    </div>

  )
}

export default FleetHeader
```

