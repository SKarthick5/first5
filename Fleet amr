# 7. src/components/RobotMap.js

```javascript
import React from 'react'

import {
  Stage,
  Layer,
  Rect,
  Circle,
  Arrow,
  Text
} from 'react-konva'

function RobotMap({ robots }) {

  const SCALE = 50

  return (

    <div className='bg-white rounded-2xl shadow p-4'>

      <h1 className='text-2xl font-bold mb-4'>Warehouse Map</h1>

      <Stage width={900} height={700}>

        <Layer>

          <Rect
            x={0}
            y={0}
            width={900}
            height={700}
            fill='#f5f5f5'
          />

          {/* Shelves */}

          <Rect x={150} y={100} width={100} height={300} fill='gray' />
          <Rect x={350} y={100} width={100} height={300} fill='gray' />
          <Rect x={550} y={100} width={100} height={300} fill='gray' />

          {/* Charging Area */}

          <Rect x={700} y={500} width={120} height={120} fill='green' />

          <Text
            x={710}
            y={550}
            text='Charging'
            fontSize={20}
          />

        </Layer>

        <Layer>

          {
            Object.entries(robots).map(([name, robot], index) => {

              const x = robot.x * SCALE + 400
              const y = 350 - robot.y * SCALE

              return (

                <React.Fragment key={name}>

                  <Circle
                    x={x}
                    y={y}
                    radius={20}
                    fill={robot.active ? 'blue' : 'red'}
                  />

                  <Arrow
                    x={x}
                    y={y}
                    points={[
                      0,
                      0,
                      Math.cos(robot.yaw) * 30,
                      -Math.sin(robot.yaw) * 30
                    ]}
                    stroke='black'
                    fill='black'
                    pointerLength={10}
                    pointerWidth={10}
                  />

                  <Text
                    x={x - 25}
                    y={y - 40}
                    text={name}
                    fontSize={16}
                  />

                </React.Fragment>

              )

            })
          }

        </Layer>

      </Stage>

    </div>

  )
}

export default RobotMap
```

