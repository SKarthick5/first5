# 10. src/components/JoystickControl.js

```javascript
import React from 'react'

import { Joystick } from 'react-joystick-component'

import ROSLIB from 'roslib'

import ros from '../ros/ros'

function JoystickControl({ robotName }) {

  const cmdVel = new ROSLIB.Topic({
    ros: ros,
    name: `/${robotName}/cmd_vel`,
    messageType: 'geometry_msgs/msg/Twist'
  })

  const handleMove = (event) => {

    const linearX = event.y / 50
    const angularZ = -event.x / 50

    const twist = new ROSLIB.Message({
      linear: {
        x: linearX,
        y: 0,
        z: 0
      },
      angular: {
        x: 0,
        y: 0,
        z: angularZ
      }
    })

    cmdVel.publish(twist)

  }

  const handleStop = () => {

    const twist = new ROSLIB.Message({
      linear: {
        x: 0,
        y: 0,
        z: 0
      },
      angular: {
        x: 0,
        y: 0,
        z: 0
      }
    })

    cmdVel.publish(twist)

  }

  return (

    <div>

      <Joystick
        size={100}
        baseColor='gray'
        stickColor='blue'
        move={handleMove}
        stop={handleStop}
      />

    </div>

  )
}

export default JoystickControl
```

