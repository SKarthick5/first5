import React, {

  useEffect,
  useState

} from 'react'

import ROSLIB from 'roslib'

function App() {

  const [fleetData, setFleetData] =
    useState({

      robots: [],

      total_robots: 0,

      active_robots: 0,

      inactive_robots: 0

    })

  useEffect(() => {

    const ros = new ROSLIB.Ros({

      url: 'ws://localhost:9090'

    })

    const fleetTopic = new ROSLIB.Topic({

      ros: ros,

      name: '/fleet_data',

      messageType: 'std_msgs/msg/String'

    })

    fleetTopic.subscribe((msg) => {

      const data = JSON.parse(msg.data)

      setFleetData(data)

    })

  }, [])

  return (

    <div>

      <h1>
        AMR Fleet Monitor
      </h1>

      <div>

        <h2>
          Total Robots:
          {fleetData.total_robots}
        </h2>

        <h2>
          Active:
          {fleetData.active_robots}
        </h2>

        <h2>
          Inactive:
          {fleetData.inactive_robots}
        </h2>

      </div>

      <div>

        {

          fleetData.robots.map(robot => (

            <div key={robot.name}>

              <h3>
                {robot.name}
              </h3>

              <p>
                Status:
                {
                  robot.active
                    ? 'ACTIVE'
                    : 'INACTIVE'
                }
              </p>

              <p>
                Position:
                ({robot.x.toFixed(2)},
                {robot.y.toFixed(2)})
              </p>

              <p>
                Battery:
                {robot.battery}%
              </p>

              <p>
                Task:
                {robot.task}
              </p>

            </div>

          ))

        }

      </div>

    </div>

  )

}

export default App
